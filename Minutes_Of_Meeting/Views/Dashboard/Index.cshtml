@model Minutes_Of_Meeting.Models.DashboardViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<link rel="stylesheet" href="~/css/DashBord.css" />

<div class="dashboard-container">

    <!-- ================= HEADER ================= -->
    <div class="header-section mb-4">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <div>
                <h4 class="fw-bold m-0">Dashboard</h4>
                <p class="text-muted small m-0">Overview & Analytics</p>
            </div>

            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-light btn-sm">
                    <i class="fas fa-bell text-muted"></i>
                </button>

                <div class="d-flex align-items-center gap-2 border rounded-pill px-3 py-1 bg-white">
                    <div class="avatar-circle">A</div>
                    <small class="fw-bold">Admin</small>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2">
            <button class="btn btn-light btn-sm text-primary" onclick="window.location.reload()">
                <i class="fas fa-sync-alt"></i> Refresh
            </button>
            <button class="btn btn-success btn-sm text-white">
                <i class="fas fa-download"></i> Export
            </button>
        </div>
    </div>

    <!-- ================= STATS ================= -->
    <div class="row g-3 mb-4">

        <div class="col-md-3 col-sm-6">
            <div class="stat-card bg-light-purple">
                <div class="d-flex justify-content-between">
                    <div>
                        <h3 class="fw-bold mb-0">@Model.TotalMeetings</h3>
                        <div class="text-muted small">TOTAL MEETINGS</div>
                    </div>
                    <div class="icon-box bg-purple">
                        <i class="fas fa-calendar"></i>
                    </div>
                </div>
                <span class="badge-trend badge-up">
                    <i class="fas fa-arrow-up"></i> 12%
                </span>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="stat-card bg-light-green">
                <div class="d-flex justify-content-between">
                    <div>
                        <h3 class="fw-bold mb-0">@Model.UpcomingMeetings</h3>
                        <div class="text-muted small">UPCOMING</div>
                    </div>
                    <div class="icon-box bg-green">
                        <i class="fas fa-clock"></i>
                    </div>
                </div>
                <span class="badge-trend badge-up">
                    <i class="fas fa-arrow-up"></i> 8%
                </span>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="stat-card bg-light-blue">
                <div class="d-flex justify-content-between">
                    <div>
                        <h3 class="fw-bold mb-0">@Model.CompletedMeetings</h3>
                        <div class="text-muted small">COMPLETED</div>
                    </div>
                    <div class="icon-box bg-blue">
                        <i class="fas fa-check-circle"></i>
                    </div>
                </div>
                <span class="badge-trend badge-up">
                    <i class="fas fa-arrow-up"></i> 15%
                </span>
            </div>
        </div>

        <div class="col-md-3 col-sm-6">
            <div class="stat-card bg-light-orange">
                <div class="d-flex justify-content-between">
                    <div>
                        <h3 class="fw-bold mb-0">@Model.CancelledMeetings</h3>
                        <div class="text-muted small">CANCELLED</div>
                    </div>
                    <div class="icon-box bg-orange">
                        <i class="fas fa-times-circle"></i>
                    </div>
                </div>
                <span class="badge-trend badge-down">
                    <i class="fas fa-arrow-down"></i> 3%
                </span>
            </div>
        </div>

    </div>

    <!-- ================= CHARTS ================= -->
    <div class="row g-3">

        <div class="col-md-6">
            <div class="chart-card">
                <div class="d-flex justify-content-between mb-2">
                    <h6 class="fw-bold m-0">Meetings by Type</h6>
                    <i class="fas fa-download text-muted"></i>
                </div>
                <div class="chart-container">
                    <canvas id="typeChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="chart-card">
                <div class="d-flex justify-content-between mb-2">
                    <h6 class="fw-bold m-0">Meetings by Department</h6>
                    <i class="fas fa-download text-muted"></i>
                </div>
                <div class="chart-container">
                    <canvas id="deptChart"></canvas>
                </div>
            </div>
        </div>

        <div class="row g-3 mt-1">
            <div class="col-md-8">
                <div class="chart-card">
                    <div class="d-flex justify-content-between mb-2">
                        <h6 class="fw-bold m-0">Meeting Trends (Monthly)</h6>
                        <div class="dropdown">
                            <i class="fas fa-ellipsis-v text-muted" style="cursor:pointer;" data-bs-toggle="dropdown"></i>
                        </div>
                    </div>
                    <div class="chart-container">
                        <canvas id="trendChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Serialize data from server
            const typeDataJson = @Html.Raw(JsonSerializer.Serialize(Model.TypeData));
            const deptDataJson = @Html.Raw(JsonSerializer.Serialize(Model.DeptData));
            const trendDataJson = @Html.Raw(JsonSerializer.Serialize(Model.TrendData));

            // Extract labels and values for Type Chart
            const typeLabels = typeDataJson.map(function (d) { return d.label; });
            const typeValues = typeDataJson.map(function (d) { return d.value; });

            // Extract labels and values for Department Chart
            const deptLabels = deptDataJson.map(function (d) { return d.label; });
            const deptValues = deptDataJson.map(function (d) { return d.value; });

            // Extract data for Trend Chart
            const trendLabels = trendDataJson.map(function (d) { return d.month; });
            const trendScheduled = trendDataJson.map(function (d) { return d.scheduled; });
            const trendCompleted = trendDataJson.map(function (d) { return d.completed; });

            // Type Chart (Doughnut)
            new Chart(document.getElementById('typeChart'), {
                type: 'doughnut',
                data: {
                    labels: typeLabels,
                    datasets: [{
                        data: typeValues,
                        backgroundColor: ['#7367f0', '#28c76f', '#00cfe8', '#ff9f43'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    cutout: '75%',
                    plugins: { legend: { position: 'right' } }
                }
            });

            // Department Chart (Bar)
            new Chart(document.getElementById('deptChart'), {
                type: 'bar',
                data: {
                    labels: deptLabels,
                    datasets: [{
                        data: deptValues,
                        backgroundColor: '#7367f0',
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true } }
                }
            });

            // Trend Chart (Line)
            new Chart(document.getElementById('trendChart'), {
                type: 'line',
                data: {
                    labels: trendLabels,
                    datasets: [{
                        label: 'Scheduled',
                        data: trendScheduled,
                        borderColor: '#7367f0',
                        backgroundColor: 'rgba(115, 103, 240, 0.1)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 4
                    }, {
                        label: 'Completed',
                        data: trendCompleted,
                        borderColor: '#28c76f',
                        backgroundColor: 'transparent',
                        borderDash: [5, 5],
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { position: 'top', labels: { usePointStyle: true } } },
                    scales: {
                        y: { grid: { color: '#f0f0f0' } },
                        x: { grid: { display: false } }
                    }
                }
            });
        });
    </script>
}
