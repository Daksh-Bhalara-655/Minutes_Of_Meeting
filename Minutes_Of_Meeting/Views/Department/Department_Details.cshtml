@model Minutes_Of_Meeting.Models.DepartmentModel

@{
    ViewData["Title"] = "Department Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Modern UI Customizations */
    .glass-card {
        background: #ffffff;
        border: 1px solid rgba(0, 0, 0, 0.05);
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.04);
        transition: transform 0.3s ease;
    }

    .icon-box {
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 14px;
        font-size: 1.5rem;
    }

    /* Soft color variations for icons */
    .bg-soft-primary {
        background-color: rgba(13, 110, 253, 0.1);
        color: #0d6efd;
    }

    .bg-soft-info {
        background-color: rgba(13, 202, 240, 0.1);
        color: #0dcaf0;
    }

    .bg-soft-success {
        background-color: rgba(25, 135, 84, 0.1);
        color: #198754;
    }

    .bg-soft-warning {
        background-color: rgba(255, 193, 7, 0.1);
        color: #ffc107;
    }

    .detail-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Elegant buttons */
    .btn-custom {
        border-radius: 8px;
        padding: 10px 24px;
        font-weight: 500;
        transition: all 0.2s ease-in-out;
    }

        .btn-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0,0,0,0.1);
        }
</style>

<div class="container mt-5" style="max-width: 800px;">

    <div class="d-flex justify-content-between align-items-end mb-4 px-2">
        <div>
            <h2 class="fw-bold mb-1" style="background: linear-gradient(45deg, #2b5876, #4e4376); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                Department Overview
            </h2>
            <p class="text-muted mb-0">Detailed information and metadata</p>
        </div>
    </div>

    <div class="card glass-card rounded-4 overflow-hidden">

        <div class="card-body p-5">
            <div class="row g-4">

                <div class="col-md-6">
                    <div class="d-flex align-items-center p-3 rounded-4 bg-light bg-opacity-50 border border-light">
                        <div class="icon-box bg-soft-info me-3">
                            <i class="bi bi-hash"></i>
                        </div>
                        <div>
                            <div class="text-muted detail-label fw-bold">Department ID</div>
                            <div class="fs-5 fw-semibold text-dark">@Model.DepartmentID</div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="d-flex align-items-center p-3 rounded-4 bg-light bg-opacity-50 border border-light">
                        <div class="icon-box bg-soft-primary me-3">
                            <i class="bi bi-building"></i>
                        </div>
                        <div>
                            <div class="text-muted detail-label fw-bold">Department Name</div>
                            <div class="fs-5 fw-semibold text-dark">@Model.DepartmentName</div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="d-flex align-items-center p-3 rounded-4 bg-light bg-opacity-50 border border-light">
                        <div class="icon-box bg-soft-success me-3">
                            <i class="bi bi-calendar-plus"></i>
                        </div>
                        <div>
                            <div class="text-muted detail-label fw-bold">Created Date</div>
                            <div class="fs-5 fw-semibold text-dark">
                                @(Model.Created?.ToString("dd MMM yyyy") ?? "N/A")
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="d-flex align-items-center p-3 rounded-4 bg-light bg-opacity-50 border border-light">
                        <div class="icon-box bg-soft-warning me-3">
                            <i class="bi bi-clock-history"></i>
                        </div>
                        <div>
                            <div class="text-muted detail-label fw-bold">Last Modified</div>
                            <div class="fs-5 fw-semibold text-dark">
                                @(Model.Modified?.ToString("dd MMM yyyy") ?? "N/A")
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <div class="card-footer bg-white border-top-0 px-5 pb-4 pt-2 d-flex justify-content-end gap-3">
            <a asp-action="Index" class="btn btn-light btn-custom border">
                <i class="bi bi-arrow-left me-1"></i> Back to List
            </a>
            <a asp-action="AddEdit" asp-route-id="@Model.DepartmentID" class="btn btn-primary btn-custom shadow-sm">
                <i class="bi bi-pencil-square me-1"></i> Edit Department
            </a>
        </div>

    </div>
</div>