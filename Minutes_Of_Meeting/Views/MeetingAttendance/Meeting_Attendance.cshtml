@model IEnumerable<Minutes_Of_Meeting.Models.MeetingAttendanceModel>

@{
    ViewData["Title"] = "Meeting Attendance";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    int totalStaff = Model != null ? Model.Count() : 0;
}

<link rel="stylesheet" href="~/css/meeting-attendance.css" />

<div class="container-fluid">

    <!-- HEADER -->
    <div class="attendance-header mb-3">
        <i class="bi bi-calendar-check"></i>
        <strong>Attendance</strong>
        | Date:
        <span>
            @{
                var selectedDate = string.IsNullOrEmpty(Context.Request.Query["MeetingDate"])
                ? DateTime.Today
                : DateTime.Parse(Context.Request.Query["MeetingDate"]);
            }
            @selectedDate.ToString("dd-MM-yyyy")
        </span>
        | Time Slot: <span>11:40 AM - 1:10 PM</span>
        | Total Staff: <span class="badge bg-primary">@totalStaff</span>
    </div>

    <!-- FILTER SECTION -->
    <div class="card filter-card mb-3">
        <div class="card-body">

            <!-- FORM ADDED (No Design Change) -->
            <form method="post" asp-action="SaveAttendance" asp-controller="MeetingAttendance">
                <input type="hidden" name="MeetingId" value="@Context.Request.Query["id"]" />
                <div class="row g-3">

                    <div class="col-md-3">
                        <label class="form-label">Meeting Date</label>
                        <input type="date"
                               class="form-control"
                               name="MeetingDate"
                               value="@(string.IsNullOrEmpty(Context.Request.Query["MeetingDate"])
                                                                                                      ? DateTime.Today.ToString("yyyy-MM-dd")
                                                                                                      : Context.Request.Query["MeetingDate"])" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Department</label>
                        <select class="form-select" asp-items="@ViewBag.DepartmentList">
                            <option value="" disabled selected>Select Department</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Meeting Type</label>
                        <select class="form-select" asp-items="@ViewBag.MeetingTypeList">
                            <option disabled selected>Select Meeting Type</option>
                        </select>
                    </div>

                    <div class="col-md-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary-custom w-100">
                            <i class="bi bi-funnel"></i> Filter
                        </button>
                    </div>

                </div>
            </form>

        </div>
    </div>

    <!-- ATTENDANCE TYPE -->
    <div class="card mb-3">
        <div class="card-body">
            <strong>Attendance Type:</strong>
            <div class="form-check form-check-inline ms-3">
                <input class="form-check-input" type="radio" checked>
                <label class="form-check-label">Present</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio">
                <label class="form-check-label">Absent</label>
            </div>
        </div>
    </div>

    <!-- STAFF TABLE -->
    <div class="card custom-card">

        <div class="card-header-custom d-flex justify-content-between">
            <span><i class="bi bi-people"></i> Tick Staff Who Are Present</span>

            <div class="summary-badges">
                <span class="badge bg-primary">@totalStaff Total</span>
                <span class="badge bg-success">0 Present</span>
                <span class="badge bg-danger">0 Absent</span>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered align-middle mb-0">
                <thead>
                    <tr>
                        <th width="40"></th>
                        <th>Staff ID</th>
                        <th>Staff Name</th>
                        <th>Department</th>
                        <th>Attendance %</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var staff in Model)
                        {
                            <tr class="@(staff.IsPresent ? "present-row" : "absent-row")">
                                <td>
                                    <input type="checkbox" @(staff.IsPresent ? "checked" : "") />
                                </td>
                                <td>WMP00 @staff.StaffID</td>
                                <td>@staff.StaffName</td>
                                <td>
                                    <span class="badge bg-info">@staff.DepartmentName</span>
                                </td>
                                <td class="
                                    @(staff.AttendancePercent > 75 ? "text-success" :
                                                                        staff.AttendancePercent >= 60 ? "text-warning" :
                                                                        "text-danger")">
                                    @staff.AttendancePercent.ToString("0.00")%
                                </td>
                                <td>
                                    <input type="checkbox"
                                           name="PresentStaff"
                                           value="@staff.StaffID"
                                    @(staff.IsPresent ? "checked" : "") />
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer text-end">
            <button type="submit" class="btn btn-success">
                <i class="bi bi-save"></i> Save Attendance
            </button>
        </div>

        <a asp-action="ExportAttendanceExcel"
               asp-controller="MeetingAttendance"
               asp-route-id="@Context.Request.Query["id"]"
               asp-route-MeetingDate="@Context.Request.Query["MeetingDate"]"
               class="btn btn-secondary mt-3">
            <i class="bi bi-file-earmark-excel"></i> Export Excel
        </a>

    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const checkboxes = document.querySelectorAll("tbody input[type='checkbox']");
        const presentBadge = document.querySelector(".bg-success");
        const absentBadge = document.querySelector(".bg-danger");

        function updateCounts() {
            let present = 0;
            let absent = 0;

            checkboxes.forEach(cb => {
                cb.checked ? present++ : absent++;
            });

            presentBadge.innerText = present + " Present";
            absentBadge.innerText = absent + " Absent";
        }

        checkboxes.forEach(cb => {
            cb.addEventListener("change", updateCounts);
        });

        updateCounts();
    });

   
</script>