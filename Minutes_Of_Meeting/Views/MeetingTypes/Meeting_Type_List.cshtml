@model IEnumerable<Minutes_Of_Meeting.Models.MeetingTypeModel>
@{
    ViewData["Title"] = "Meeting Types";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


    <link rel="stylesheet" href="~/css/meeting-type-list.css" asp-append-version="true" />


<div class="container py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="main-title">Meeting Types</h4>
            <p class="sub-title">Manage meeting types</p>
        </div>
        <a asp-controller="MeetingTypes"
           asp-action="Create"
           class="btn btn-primary-custom">
            <i class="bi bi-plus-circle"></i> Add Meeting Type
        </a>
    </div>

    <!-- CARD -->
    <div class="card custom-card">

        <div class="card-header-custom">
            <i class="bi bi-calendar-event"></i>
            Meeting Type List
        </div>

        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Meeting Type Name</th>
                        <th>Remarks</th>
                        <th>Created</th>
                        <th>Modified</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var meetingType in Model)
                        {
                            <tr>
                                <td>@meetingType.MeetingTypeID</td>
                                <td>@meetingType.MeetingTypeName</td>
                                <td>@meetingType.Remarks</td>
                                <td>@meetingType.Created</td>
                                <td>@meetingType.Modified</td>

                                <td class="text-end">
                                    <div class="action-btn-group">
                                        <a asp-controller="MeetingTypes"
                                           asp-action="Details"
                                           asp-route-id="@meetingType.MeetingTypeID"
                                           class="action-btn view">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a asp-controller="MeetingTypes"
                                           asp-action="Create"
                                           asp-route-id="@meetingType.MeetingTypeID"
                                           class="action-btn edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <a asp-controller="MeetingTypes"
                                           asp-action="Delete"
                                           asp-route-id="@meetingType.MeetingTypeID"
                                           class="action-btn delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">
                                No Meeting Types Found
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>

    </div>

</div>
