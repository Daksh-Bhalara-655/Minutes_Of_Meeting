@model Minutes_Of_Meeting.Models.MeetingsModel
@{
    // Determine if we are in Edit mode or Create mode
    bool isEdit = Model != null && Model.MeetingID > 0;
    ViewData["Title"] = isEdit ? "Edit Meeting" : "Schedule New Meeting";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    ViewData["Title"] = "Schedule New Meeting";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/create-meeting.css" asp-append-version="true" />

<div class="create-meeting-page container-fluid py-5 px-4">

    <!-- ================= HEADER ================= -->
    <div class="row justify-content-center mb-5">
        <div class="col-lg-10">
            @* Dynamic Title *@
            <h2 class="fw-bold text-dark m-0">@(isEdit ? "Edit Meeting" : "Schedule New Meeting")</h2>
            <p class="text-muted m-0">@(isEdit ? "Update the details of your existing meeting" : "Create and schedule a new organizational meeting")</p>
        </div>
    </div>

    <!-- ================= FORM CARD ================= -->
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card-modern">
                
                <div class="card-header-modern">
                    <h5 class="card-title m-0">
                        <i class="bi @(isEdit ? "bi-pencil-square" : "bi-calendar-plus") me-2"></i>
                        @(isEdit ? "Update Meeting Details" : "Schedule New Meeting")
                    </h5>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Save" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="MeetingID" />
                        <div class="row g-4">
                            
                            <!-- Meeting Type -->
                            <div class="col-md-6">
                                <label asp-for="MeetingTypeId" class="form-label">Meeting Type</label>                                <div class="input-group">
                                    <span class="input-group-text border-end-0"><i class="bi bi-tag"></i></span>
                                    <select asp-for="MeetingTypeId"
                                            asp-items="ViewBag.MeetingTypeList"
                                            class="form-select">
                                        <option value="">-- Select Meeting Type --</option>
                                    </select>
                                    <span asp-validation-for="MeetingTypeId" class="text-danger"></span>
                                </div>
                            </div>

                            <!-- Department -->
                            <div class="col-md-6">
                                <label asp-for="DepartmentID" class="form-label">Department</label>
                                <div class="input-group">
                                    <span class="input-group-text border-end-0"><i class="bi bi-building"></i></span>
                                    <select asp-for="DepartmentID"
                                            asp-items="ViewBag.DepartmentList"
                                            class="form-select">
                                        <option value="">-- Select Department --</option>
                                    </select>
                                    <span asp-validation-for="DepartmentID" class="text-danger"></span>
                                </div>
                            </div>

                            <!-- Venue -->
                            <div class="col-md-6">
                            <label asp-for="MeetingVenueId" class="form-label">Venue</label>                                <div class="input-group">
                                    <span class="input-group-text border-end-0"><i class="bi bi-geo-alt"></i></span>
                                    <select asp-for="MeetingVenueId"
                                            asp-items="ViewBag.MeetingvenueList"
                                            class="form-select">
                                        <option value="">-- Select Venue --</option>
                                    </select>
                                    <span asp-validation-for="MeetingVenueId" class="text-danger"></span>
                                </div>
                            </div>

                            <!-- Meeting Date & Time -->
                            <div class="col-md-6">
                                <label asp-for="MeetingDate" class="form-label">Meeting Date & Time</label>
                                <div class="input-group">
                                    <span class="input-group-text border-end-0"><i class="bi bi-calendar"></i></span>
                            <input asp-for="MeetingDate"
                                   type="date"                                   
                                   class="form-control" />
                                    </div>
                                    <span asp-validation-for="MeetingDate" class="text-danger"></span>
                            </div>

                            <!-- Meeting Description -->
                            <div class="col-12">
                                <label asp-for="MeetingDescription" class="form-label">Meeting Description</label>
                                <div class="input-group">
                                    <span class="input-group-text border-end-0 align-items-start pt-3"><i class="bi bi-chat-dots"></i></span>
                                    <textarea asp-for="MeetingDescription"
                                              class="form-control"></textarea>
                                </div>
                                <span asp-validation-for="MeetingDescription" class="text-danger"></span>
                            </div>

                            <!-- Meeting Document -->
                    <div class="col-12">
                        <label asp-for="DocumentPath" class="form-label">
                            <i class="bi bi-paperclip me-2"></i>Meeting Document (Optional)
                        </label>

                        <input type="file" name="file" class="form-control" />

                        <div class="form-text mt-2 text-muted">
                            Upload meeting document (PDF, DOC, etc.)
                        </div>
                    </div>

                            <!-- Action Buttons -->
                    <div class="row g-4">
                        <div class="col-12 mt-4 d-flex justify-content-end align-items-center gap-3">
                            <a asp-controller="Meetings" asp-action="Index" class="back-link">
                                <i class="bi bi-arrow-left"></i> Back to Meetings
                            </a>
                            <button type="submit" class="btn btn-primary-custom">
                                <i class="bi bi-check-circle me-2"></i>
                                @* Dynamic Button Text *@
                                @(isEdit ? "Update Meeting" : "Schedule Meeting")
                            </button>
                        </div>

                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

</div>