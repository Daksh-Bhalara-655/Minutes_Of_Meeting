@model IEnumerable<Minutes_Of_Meeting.Models.MeetingsModel>

@section Styles {
    <link rel="stylesheet" href="~/css/meetinglist.css" />
}

<h2 class="main-title">Meetings</h2>
<p class="sub-title">Manage organization meetings</p>



<table class="table table-hover mb-0">
    <thead>
        <tr>
            <th>Date</th>
            <th>Department</th>
            <th>Type</th>
            <th>Venue</th>
            <th>Description</th>
            <th>Status</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var m in Model)
        {
            <tr>
                <td>@m.MeetingDate.ToString("yyyy-MM-dd")</td>
                <td>@m.DepartmentName</td>
                <td>@m.MeetingTypeName</td>
                <td>@m.MeetingVenueName</td>
                <td>@m.MeetingDescription</td>
                <td>
                    @if (m.IsCancelled)
                    {
                        <span class="badge badge-cancel">Cancelled</span>
                    }
                    else
                    {
                        <span class="badge badge-active">Active</span>
                    }
                </td>

                <td class="text-end">
                    <div class="action-btn-group">
                        <a asp-controller="Meetings" asp-action="Detail" class="action-btn view">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-controller="Meetings"
                               asp-action="Create"
                               asp-route-id="@m.MeetingID"
                               class="action-btn edit">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-controller="Meetings"
                               asp-action="Delete"
                               asp-route-id="@m.MeetingID"
                               class="action-btn delete">
                            <i class="bi bi-trash"></i>
                        </a>
                        <a asp-controller="MeetingAttendance"
                               asp-action="Index"
                               asp-route-id="@m.MeetingID"
                               asp-route-MeetingDate="@m.MeetingDate.ToString("yyyy-MM-dd")"
                               class="action-btn attendance btn-info"
                               title="Manage Attendance">
                            <i class="bi bi-person-check"></i>
                        </a>
                        @* <a asp-controller="MeetingMembers"
                               asp-action="Index"
                               asp-route-MeetingId="@m.MeetingID"
                               class="action-btn add-member">
                            <i class="bi bi-person-plus"></i>
                        </a> *@
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>