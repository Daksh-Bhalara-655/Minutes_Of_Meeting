@model List<Minutes_Of_Meeting.Models.MeetingsModel>

@{
    ViewData["Title"] = "Meetings";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/meetinglist.css" />

<div class="container">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="main-title">Meetings</h2>
            <p class="sub-title">Manage organization meetings</p>
        </div>

        <a asp-action="Create" class="btn btn-add">
            <i class="bi bi-plus-circle"></i> Add Meeting
        </a>
    </div>

    <!-- Card -->
    <div class="card custom-card">

        <div class="card-header-custom">
            <i class="bi bi-calendar-event"></i>
            Meeting List
        </div>

        <div class="card-body p-0">

            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Department</th>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Type</th>
                        <th>Venue</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @{
                        int count = 1;
                    }

                    @foreach (var meeting in Model)
                    {
                        <tr>
                            <td>@count</td>
                            <td>@meeting.DepartmentName</td>
                            <td>@meeting.MeetingDate.ToString("dd-MM-yyyy HH:mm:ss")</td>
                            <td>@meeting.MeetingDescription</td>
                            <td>@meeting.MeetingTypeName</td>
                            <td>@meeting.MeetingVenueName</td>
                            <td>
                                @if (meeting.IsCancelled)
                                {
                                    <span class="badge badge-cancel">Cancelled</span>
                                }
                                else
                                {
                                    <span class="badge badge-active">Active</span>
                                }
                            </td>

                            <td class="text-end">
                                <div class="action-btn-group">
                                    <a asp-controller="Meetings" asp-action="Detail" class="action-btn view">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-controller="Meetings"
                                       asp-action="Create"
                                        class="action-btn edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-controller="Meetings"
                                       asp-action="Delete"

                                        class="action-btn delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                    <a asp-controller="MeetingAttendance"
                                       asp-action="Index"
                                       asp-route-id="@meeting.MeetingID"
                                       asp-route-MeetingDate="@meeting.MeetingDate.ToString("yyyy-MM-dd")"
                                       class="action-btn attendance btn-info"
                                       title="Manage Attendance">
                                        <i class="bi bi-person-check"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>

                        count++;
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>