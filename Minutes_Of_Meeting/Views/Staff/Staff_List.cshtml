@model IEnumerable<Minutes_Of_Meeting.Models.Staff>
@{
    ViewData["Title"] = "Staff Members";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int staff_Count = Model != null ? Model.Count() : 0;
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/staff-list.css" asp-append-version="true" />

<div class="staff-list-page container-fluid py-5 px-xl-5">

    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h2 class="fw-bold text-dark m-0">Staff Directory</h2>
            <p class="text-muted mt-1 mb-0">Manage your team members and their meeting participation.</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <button class="btn btn-light shadow-sm me-2 border-0 fw-semibold text-success">
                <i class="bi bi-file-earmark-excel-fill me-1 text-success"></i> Export CSV
            </button>
            <a asp-action="Create" class="btn btn-primary-gradient shadow-sm fw-semibold">
                <i class="bi bi-person-plus-fill me-1"></i> Add New Staff
            </a>
        </div>
    </div>

    <div class="card-modern p-4 mb-4 border-0">
        <div class="row g-3 align-items-center">
            <div class="col-lg-3 col-md-4">
                <div class="form-floating">
                    <select id="departmentFilter" class="form-select border-0 bg-light" asp-items="@ViewBag.DepartmentList">
                        <option value="">All Departments</option>
                    </select>
                    <label>Filter by Department</label>
                </div>
            </div>

            <div class="col-lg-5 col-md-8">
                <div class="search-box position-relative">
                    <i class="bi bi-search position-absolute top-50 translate-middle-y text-muted ms-3"></i>
                    <input id="staffSearch" class="form-control border-0 bg-light py-3 ps-5" placeholder="Search by name, email, or ID..." />
                </div>
            </div>

            <div class="col-lg-4 ms-auto text-lg-end text-muted fw-medium">
                Showing <strong id="staffCount" class="text-dark">@staff_Count</strong> members
            </div>
        </div>
    </div>

    <div class="card-modern p-0 border-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 custom-table" id="staffTable">
                <thead>
                    <tr>
                        <th class="ps-4">Staff Member</th>
                        <th>Department</th>
                        <th>Contact Info</th>
                        <th>Joined Date</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var staff in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3 py-1">
                                        <div class="avatar-circle shadow-sm">
                                            @(string.IsNullOrEmpty(staff.StaffName) ? "?" : staff.StaffName.Substring(0, 1).ToUpper())
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-bold text-dark">@staff.StaffName</h6>
                                            <small class="text-muted">ID: #@staff.StaffID</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="custom-badge badge-soft-primary">@staff.DepartmentName</span>
                                </td>
                                <td>
                                    <div class="text-dark fw-medium">@staff.EmailAddress</div>
                                </td>
                                <td>
                                    <div class="text-muted"><i class="bi bi-calendar3 me-1"></i> @staff.Created.ToString("MMM dd, yyyy")</div>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="action-btn-group">
                                        <a asp-controller="Staff" asp-action="Details" asp-route-id="@staff.StaffID" class="action-btn btn-view" title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-controller="Staff" asp-action="Create" asp-route-id="@staff.StaffID" class="action-btn btn-edit" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a href="#" class="action-btn btn-delete" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">
                                <div class="text-center py-5">
                                    <div class="display-1 text-muted opacity-25 mb-3"><i class="bi bi-inbox"></i></div>
                                    <h5 class="fw-bold text-dark">No Staff Members Found</h5>
                                    <p class="text-muted">Try adjusting your filters or add a new staff member.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Simple search & filter script combined
        document.getElementById("staffSearch").addEventListener("keyup", filterTable);
        document.getElementById("departmentFilter").addEventListener("change", filterTable);

        function filterTable() {
            const searchVal = document.getElementById("staffSearch").value.toLowerCase();
            const deptVal = document.getElementById("departmentFilter").value.toLowerCase();
            const rows = document.querySelectorAll("#staffTable tbody tr");
            let count = 0;

            rows.forEach(row => {
                // If it's the "No members found" row, skip it
                if(row.cells.length === 1) return;

                const nameEmailCell = row.cells[0].innerText.toLowerCase() + " " + row.cells[2].innerText.toLowerCase();
                const deptCell = row.cells[1].innerText.toLowerCase();

                const matchesSearch = searchVal === "" || nameEmailCell.includes(searchVal);
                const matchesDept = deptVal === "" || deptCell.includes(deptVal);

                if (matchesSearch && matchesDept) {
                    row.style.display = "";
                    count++;
                } else {
                    row.style.display = "none";
                }
            });

            document.getElementById("staffCount").innerText = count;
        }
    </script>
}