@model IEnumerable<Minutes_Of_Meeting.Models.Staff>
@{
    ViewData["Title"] = "Staff Members";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@{
    int count_Staff = 0;
    foreach (var staff in Model)
    {
        count_Staff++;
    }
}

<link rel="stylesheet" href="~/css/staff-list.css" asp-append-version="true" />

<div class="staff-list-page container-fluid py-5 px-4">

    <div class="row mb-5 align-items-center">
        <div class="col-md-6">
            <h2 class="fw-bold m-0">Staff Members</h2>
            <p class="text-muted">Manage staff members and their meeting participation</p>
        </div>
        <div class="col-md-6 text-md-end">
            <a asp-action="Create" class="btn btn-primary-gradient me-2">
                <i class="bi bi-person-plus-fill me-1"></i> Add Staff Member
            </a>
            <button class="btn btn-success-gradient">
                <i class="bi bi-file-earmark-excel me-1"></i> Export
            </button>
        </div>
    </div>

    <div class="card-modern p-4 mb-4">
        <div class="row g-3 align-items-end">
            <div class="col-md-2">
                <label class="form-label">Department</label>
                <select id="departmentFilter" class="form-select" asp-items="ViewBag.DepartmentList">
                    <option value="">All Departments</option>

                </select>
            </div>


            <div class="col-md-4">
                <label class="form-label">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-white">
                        <i class="bi bi-search"></i>
                    </span>
                    <input id="staffSearch" class="form-control" placeholder="Search staff..." />
                </div>
            </div>

            <div class="col-md-auto ms-auto d-flex align-items-center gap-3">
                <a class="text-primary text-decoration-none fw-semibold">Search</a>
                <a class="text-muted text-decoration-none">Clear</a>
                <span class="text-muted">Total: <strong id="staffCount">@count_Staff</strong></span>
            </div>
        </div>
    </div>

    <div class="card-modern p-0">
        <div class="card-header-modern">
            <h5 class="m-0">
                <i class="bi bi-people-fill me-2"></i> Staff Members List
            </h5>
        </div>

        <div class="table-responsive">
            <table class="table align-middle mb-0" id="staffTable">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Staff Name</th>
                        <th>Department</th>
                        <th>Email Address</th>
                        <th>Created Date</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>

                    @if(Model != null && Model.Any())
                    {
                    @foreach(var staff in Model)
                    {
                        <tr>
                            <td>@staff.StaffID</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <strong>@staff.StaffName</strong>
                                </div>
                            </td>
                            <td><span class="badge badge-info">@staff.DepartmentName</span></td>
                            <td>
                                <i class="bi bi-envelope me-1"></i>
                                @staff.EmailAddress
                            </td>
                            <td>@staff.Created.ToString("yyyy-MM-dd")</td>
                                <td class="text-end">
                                    <div class="action-btn-group">
                                        <a class="action-btn action-view"><i class="bi bi-eye"></i></a>
                                        <a class="action-btn action-schedule"><i class="bi bi-calendar-check"></i></a>
                                        <a asp-controller="Staff" asp-action="Create" class="action-btn action-edit"><i class="bi bi-pencil"></i></a>
                                        <a class="action-btn action-delete"><i class="bi bi-trash"></i></a>
                                    </div>
                                </td>
                        </tr>

                    }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                No staff members found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
                document.getElementById("departmentFilter").addEventListener("change", function () {
            const filterValue = this.value.toLowerCase();
            const rows = document.querySelectorAll("#staffTable tbody tr");

            rows.forEach(row => {
                // Assuming Department is in the 3rd column (index 2)
                const deptCell = row.cells[2].innerText.toLowerCase();
                const visible = filterValue === "" || deptCell.includes(filterValue);
                row.style.display = visible ? "" : "none";
            });
        });

    </script>
}
